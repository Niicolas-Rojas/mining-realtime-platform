# Production environment template
# Copy values from each free-tier service and set as GitHub Secrets
# or in the corresponding platform's env config.

# -------------------------------------------------------------------
# MQTT - HiveMQ Cloud (https://console.hivemq.cloud)
# Free tier: up to 100 connections, TLS required
# -------------------------------------------------------------------
MQTT_BROKER_HOST=your-cluster.hivemq.cloud
MQTT_BROKER_PORT=8883
MQTT_TOPIC=mining/sag-mill/telemetry
MQTT_CLIENT_PREFIX=mining-platform
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password
MQTT_USE_TLS=true

# -------------------------------------------------------------------
# PostgreSQL - Supabase (https://supabase.com)
# Free tier: 500 MB, SSL required
# Connection string available in: Project Settings > Database
# -------------------------------------------------------------------
POSTGRES_HOST=db.xxxxxxxxxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_SSLMODE=require

# -------------------------------------------------------------------
# Simulator settings (used by GitHub Actions scheduled workflow)
# -------------------------------------------------------------------
SIMULATOR_EQUIPMENT_ID=sag-mill-01
SIMULATOR_SITE=concentradora-norte
SIMULATOR_LINE=linea-a
SIMULATOR_INTERVAL_SECONDS=2.0
SIMULATOR_DATA_ERROR_RATE=0.03

# -------------------------------------------------------------------
# Storage paths (used locally or in GitHub Actions runner)
# -------------------------------------------------------------------
BRONZE_OUTPUT_PATH=data/bronze/raw_telemetry.ndjson
DEAD_LETTER_OUTPUT_PATH=data/dead_letter/rejected_telemetry.ndjson
SILVER_OUTPUT_PATH=data/silver/telemetry_clean.csv
SILVER_REPORT_PATH=data/silver/quality_report.json
GOLD_SUMMARY_PATH=data/gold/equipment_minute_summary.csv
GOLD_REPORT_PATH=data/gold/gold_quality_report.json
PROCESSOR_INTERVAL_SECONDS=60

# -------------------------------------------------------------------
# API - set in Render dashboard or render.yaml
# (POSTGRES_* vars above are also needed by the API)
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# Dashboard - set in Streamlit Cloud app secrets
# -------------------------------------------------------------------
API_BASE_URL=https://mining-api.onrender.com
